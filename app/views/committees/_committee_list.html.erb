<p class="mt-3">Total members: <%= @people.length %></p>
<table class="table table-sm table-striped">
  <thead class="thead-light">
    <tr>
      <th>Last Name</th>
      <th>First Name</th>
      <th>Home Phone</th>
      <th>Work Phone</th>
      <th>Cell Phone</th>
      <th>Email</th>
      <th>Committee</th>
    </tr>
  </thead>
  <tbody>
    <% @people.each do |p| %>
    <tr scope="row" %>
      <td><%= p.LastName %></td>
      <td><%= p.FirstName %></td>
      <td><%= number_to_phone(p.HomePhone, area_code: true) %></td>
      <td><%= number_to_phone(p.WorkPhone, area_code: true) %></td>
      <td><%= number_to_phone(p.CellPhone, area_code: true) %></td>
      <td><%= p.EmailAddress %></td>
      <td><%= p.Committee1 %></td>
    </tr>
    <% end %>
  </tbody>
</table>
