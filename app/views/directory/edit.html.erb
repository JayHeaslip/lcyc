<div class="card-body p-4">
  <%= form_with(model: @person, url: directory_path(@person), method: :patch, class: "needs-validation", data: { turbo: false }) do |f| %>
    
    <div class="row g-4" data-controller="photo-preview">

      <div class="col-12 col-lg-8">
        
        <h2 class="h4 fw-semibold text-dark mb-4">
          <%= "#{@person.FirstName} #{@person.LastName}" %>
        </h2>

        <div class="row g-3">

          <div class="col-12">
            <div class="row align-items-center">
              <div class="col-4 col-md-3">
                <div class="bg-light text-muted px-3 py-2 rounded fw-medium">First Name</div>
              </div>
              <div class="col-8 col-md-9">
                <%= f.text_field :FirstName, 
                     class: "form-control py-2 bg-light", 
                     placeholder: "First Name",
                     readonly: true %>
              </div>
            </div>
          </div>

          <div class="col-12">
            <div class="row align-items-center">
              <div class="col-4 col-md-3">
                <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Last Name</div>
              </div>
              <div class="col-8 col-md-9">
                <%= f.text_field :LastName, 
                     class: "form-control py-2 bg-light", 
                     placeholder: "Last Name",
                     readonly: true %>
              </div>
            </div>
          </div>

          <div class="col-12">
            <div class="row align-items-center">
              <div class="col-4 col-md-3">
                <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Email</div>
              </div>
              <div class="col-8 col-md-9">
                <%= f.email_field :EmailAddress, class: "form-control py-2", placeholder: "user@example.com" %>
              </div>
            </div>
          </div>

          <div class="col-12">
            <div class="row align-items-center">
              <div class="col-4 col-md-3">
                <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Cell Phone</div>
              </div>
              <div class="col-8 col-md-9">
                <%= f.text_field :CellPhone, class: "form-control py-2", placeholder: "(555) 123-4567" %>
              </div>
            </div>
          </div>

          <div class="col-12">
            <div class="row align-top">
              <div class="col-4 col-md-3 pt-2">
                <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Address</div>
              </div>
              <div class="col-8 col-md-9">
                <%= f.fields_for :membership, @person.membership do |m| %>
                  <div class="mb-3">
                    <%= m.label :StreetAddress, "Street Address", class: "form-label fw-medium text-muted small mb-1" %>
                    <%= m.text_field :StreetAddress, class: "form-control py-2", placeholder: "123 Main Street" %>
                  </div>

                  <div class="row g-2">
                    <div class="col-12 col-sm-6">
                      <%= m.label :City, "City", class: "form-label fw-medium text-muted small mb-1" %>
                      <%= m.text_field :City, class: "form-control py-2", placeholder: "City" %>
                    </div>
                    <div class="col-6 col-sm-3">
                      <%= m.label :State, "State", class: "form-label fw-medium text-muted small mb-1" %>
                      <%= m.text_field :State, class: "form-control py-2 text-uppercase", placeholder: "VT", maxlength: 2 %>
                    </div>
                    <div class="col-6 col-sm-3">
                      <%= m.label :Zip, "ZIP", class: "form-label fw-medium text-muted small mb-1" %>
                      <%= m.text_field :Zip, class: "form-control py-2", placeholder: "05495" %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="col-12 col-lg-4 d-flex justify-content-center justify-content-lg-end">
        <div class="text-center">
          <div class="border border-2 bg-black text-white d-flex align-items-center justify-content-center rounded mb-3"
               style="width: 220px; height: 220px; font-size: 1.1rem; text-align: center; line-height: 1.3;">
            
            <div id="photo-container-frame" 
                 data-photo-preview-target="container"
                 data-action="click->photo-preview#triggerUpload"
                 class="border border-2 border-light rounded overflow-hidden shadow-sm position-relative flex-shrink-0"
                 style="width: 260px; height: 260px; cursor: pointer;">
              
              <% if @person.profile_picture.present? %>
                <%= image_tag @person.profile_picture,
                    class: "w-100 h-100 object-cover",
                    alt: "#{@person.FirstName} #{@person.LastName} Profile Picture",
                    id: "current-photo" %>
              <% else %>
                <div id="photo-placeholder" class="d-flex align-items-center justify-content-center h-100 bg-light text-muted">
                  <div class="text-center">
                    <p class="mb-1">Photo</p>
                    <p class="mb-1">Not</p>
                    <p class="mb-0">Available</p>
                  </div>
                </div>
              <% end %>
              
              <button type="button" 
                      id="remove-photo-btn"
                      data-photo-preview-target="removeBtn"
                      data-action="click->photo-preview#remove"
                      class="btn btn-danger btn-sm position-absolute top-0 end-0 m-2"
                      style="display: none; z-index: 10; width: 32px; height: 32px; padding: 0;">
                ✕
              </button>
            </div>
          </div>

          <div>
            <%= f.label :profile_picture, "Click on photo to update", 
                    class: "text-primary fw-medium small d-block text-center mb-2" %>
            <%= f.file_field :profile_picture, 
                    class: "d-none", 
                    accept: "image/jpeg,image/png,image/gif", 
                    id: "photo-upload",
                    data: { photo_preview_target: "input", action: "change->photo-preview#preview" } %>
            
            <div class="mt-2">
              <small class="text-muted">JPG, PNG or GIF • Max 5MB</small>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 mt-4 pt-3 border-top">
        <%= f.submit "Save Changes", class: "btn btn-primary px-4 me-2" %>
        <%= link_to "Cancel", directory_path(@person), class: "btn btn-outline-secondary px-4" %>
      </div>
      <%= f.check_box :remove_photo, { style: "display: none;" }, "1", "0" %>
    </div>
  <% end %>
</div>
`<
