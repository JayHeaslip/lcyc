<div class="card-body p-4">
  <%= form_with(model: @membership, url: directory_path(@person), method: :patch, multipart: true, class: "needs-validation", data: { turbo: false }) do |f| %>
    
    <div class="row g-4">

      <div class="col-12 col-lg-8">
        
        <%= f.fields_for :people, @person, {child_index: "person"} do |p_form| %>
	  <%= p_form.hidden_field :id %>
	  <h2 class="h4 fw-semibold text-dark mb-4">
            <%= "#{@person.FirstName} #{@person.LastName}" %>
          </h2>

          <div class="row g-3">
            <div class="col-12">
              <div class="row align-items-center">
                <div class="col-4 col-md-3">
                  <div class="bg-light text-muted px-3 py-2 rounded fw-medium">First Name</div>
                </div>
                <div class="col-8 col-md-9">
                  <%= p_form.text_field :FirstName, class: "form-control py-2 bg-light", readonly: true %>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="row align-items-center">
                <div class="col-4 col-md-3">
                  <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Last Name</div>
                </div>
                <div class="col-8 col-md-9">
                  <%= p_form.text_field :LastName, class: "form-control py-2 bg-light", readonly: true %>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="row align-items-center">
                <div class="col-4 col-md-3">
                  <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Email</div>
                </div>
                <div class="col-8 col-md-9">
                  <%= p_form.email_field :EmailAddress, class: "form-control py-2", placeholder: "user@example.com" %>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="row align-items-center">
                <div class="col-4 col-md-3">
                  <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Cell Phone</div>
                </div>
                <div class="col-8 col-md-9">
                  <%= p_form.text_field :CellPhone, class: "form-control py-2", placeholder: "(555) 123-4567" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <div class="row g-3 mt-1">
          <div class="col-12">
            <div class="row align-top">
              <div class="col-4 col-md-3 pt-2">
                <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Address</div>
              </div>
              <div class="col-8 col-md-9">
                <div class="mb-3">
                  <%= f.label :StreetAddress, "Street Address", class: "form-label fw-medium text-muted small mb-1" %>
                  <%= f.text_field :StreetAddress, class: "form-control py-2", placeholder: "123 Main St" %>
                </div>

                <div class="row g-2">
                  <div class="col-12 col-sm-6">
                    <%= f.label :City, "City", class: "form-label fw-medium text-muted small mb-1" %>
                    <%= f.text_field :City, class: "form-control py-2", placeholder: "City" %>
                  </div>
                  <div class="col-6 col-sm-3">
                    <%= f.label :State, "State", class: "form-label fw-medium text-muted small mb-1" %>
                    <%= f.text_field :State, class: "form-control py-2 text-uppercase", placeholder: "VT", maxlength: 2 %>
                  </div>
                  <div class="col-6 col-sm-3">
                    <%= f.label :Zip, "ZIP", class: "form-label fw-medium text-muted small mb-1" %>
                    <%= f.text_field :Zip, class: "form-control py-2", placeholder: "05495" %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <%= f.fields_for :boats, @boat, {child_index: "boat"} do |b_text_form| %>
	  <%= b_text_form.hidden_field :id %>
          <div class="row g-3 mt-1">
            <div class="col-12">
              <div class="row align-top">
                <div class="col-4 col-md-3 pt-2">
                  <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Boat</div>
                </div>
                <div class="col-8 col-md-9">
                  <div class="row g-3">
                    <div class="col-12 col-sm-6">
                      <%= b_text_form.label :Name, "Boat Name", class: "form-label fw-medium text-muted small mb-1" %>
                      <%= b_text_form.text_field :Name, class: "form-control py-2", placeholder: "e.g., Sea Biscuit" %>
                    </div>
                    <div class="col-12 col-sm-6">
                      <%= b_text_form.label :Mfg_Size, "Boat Mfg / Type", class: "form-label fw-medium text-muted small mb-1" %>
                      <%= b_text_form.text_field :Mfg_Size, class: "form-control py-2", placeholder: "e.g., Boston Whaler 21'" %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>

      </div>

      <div class="col-12 col-lg-4 d-flex flex-column align-items-center align-items-lg-end gap-4">
        
        <%= f.fields_for :people, @person, {child_index: "person"} do |p_photo_form| %>
	  <%= p_photo_form.hidden_field :id %>
          <div class="text-center" data-controller="photo-preview">
            <div id="profile-photo-frame" 
                 data-photo-preview-target="container"
                 data-action="click->photo-preview#triggerUpload"
                 class="border border-2 border-secondary bg-light text-muted rounded overflow-hidden shadow-sm position-relative flex-shrink-0 mb-2"
                 style="width: 260px; height: 260px; cursor: pointer;">
              
              <% if @person.profile_picture.attached? && @person.profile_picture.persisted? %>
                <%= image_tag @person.profile_picture, class: "w-100 h-100 object-cover", alt: "Profile Picture", data: { photo_preview_target: "image" } %>
                <img data-photo-preview-target="image" class="w-100 h-100 object-cover d-none" alt="Profile Picture">
                <div data-photo-preview-target="placeholder" class="d-flex align-items-center justify-content-center h-100 bg-light text-muted d-none">
                  <div class="text-center">
                    <p class="mb-1 text-uppercase fw-semibold tracking-wide">Profile Photo</p>
                    <p class="mb-1 text-uppercase fw-semibold tracking-wide">Not Available</p>
                  </div>
                </div>
                <button type="button" data-photo-preview-target="removeBtn" data-action="click->photo-preview#remove" class="btn btn-danger btn-sm position-absolute top-0 end-0 m-2 d-flex align-items-center justify-content-center" style="z-index: 10; width: 32px; height: 32px; padding: 0;">✕</button>
              <% else %>
                <img data-photo-preview-target="image" class="w-100 h-100 object-cover d-none" alt="Profile Picture">
                <div data-photo-preview-target="placeholder" class="d-flex align-items-center justify-content-center h-100 bg-light text-muted">
                  <div class="text-center">
                    <p class="mb-1 text-uppercase fw-semibold tracking-wide">Profile Photo</p>
                    <p class="mb-1 text-uppercase fw-semibold tracking-wide">Not Available</p>
                  </div>
                </div>
              <% end %>
            </div>

            <div>
              <%= p_photo_form.label :profile_picture, "Click profile image to update", class: "text-primary fw-medium small d-block mb-1" %>
              <%= p_photo_form.file_field :profile_picture, class: "d-none", accept: "image/jpeg,image/png,image/gif", data: { photo_preview_target: "input", action: "change->photo-preview#preview" } %>
	      <%= p_photo_form.hidden_field :remove_profile_picture, value: "0", data: { photo_preview_target: "removeCheckbox" } %>
              <small class="text-muted d-block">Max 5MB (JPG, PNG, GIF)</small>
            </div>
          </div>
        <% end %>

        <%= f.fields_for :boats, @boat, {child_index: "boat"} do |b_form| %>
	  <%= b_form.hidden_field :id %>
          <div class="text-center mb-4" data-controller="photo-preview">
            <div id="boat-photo-frame" 
                 data-photo-preview-target="container"
                 data-action="click->photo-preview#triggerUpload"
                 class="border border-2 border-secondary bg-light text-muted rounded overflow-hidden shadow-sm position-relative flex-shrink-0 mb-2 mx-auto"
                 style="width: 260px; height: 260px; cursor: pointer;">
              
              <% if b_form.object.photo.attached? && b_form.object.photo.persisted? %>
                <%= image_tag b_form.object.photo, class: "w-100 h-100 object-cover", alt: "Boat Photo", data: { photo_preview_target: "image" } %>
                <img data-photo-preview-target="image" class="w-100 h-100 object-cover d-none" alt="Boat Photo">
                
                <div data-photo-preview-target="placeholder" class="d-flex align-items-center justify-content-center h-100 bg-light text-muted d-none">
                  <div class="text-center">
                    <p class="mb-1 text-uppercase fw-semibold tracking-wide">Boat Photo</p>
                    <p class="mb-1 text-uppercase fw-semibold tracking-wide">Not Available</p>
                  </div>
                </div>
            
                <button type="button" 
                        data-photo-preview-target="removeBtn"
                        data-action="click->photo-preview#remove"
                        class="btn btn-danger btn-sm position-absolute top-0 end-0 m-2 d-flex align-items-center justify-content-center"
                        style="z-index: 10; width: 32px; height: 32px; padding: 0;">✕</button>
              <% else %>
                <img data-photo-preview-target="image" class="w-100 h-100 object-cover d-none" alt="Boat Photo">
                
                <div data-photo-preview-target="placeholder" class="d-flex align-items-center justify-content-center h-100 bg-light text-muted">
                  <div class="text-center">
                    <p class="mb-1 text-uppercase fw-semibold tracking-wide">Boat Photo</p>
                    <p class="mb-1 text-uppercase fw-semibold tracking-wide">Not Available</p>
                  </div>
                </div>
              <% end %>
            </div>
            
            <div>
              <%= b_form.label :photo, b_form.object.persisted? ? "Click image to update boat photo" : "Upload Boat Photo", class: "text-primary fw-medium small d-block mb-1" %>
              <%= b_form.file_field :photo, 
                    class: "d-none", 
                    accept: "image/jpeg,image/png,image/gif", 
                    data: { photo_preview_target: "input", action: "change->photo-preview#preview" } %>
	      <%= b_form.hidden_field :remove_photo, value: "0", data: { photo_preview_target: "removeCheckbox" } %>
            </div>
          </div>
        <% end %>
        
      </div>

      <div class="col-12 mt-4 pt-3 border-top">
        <%= f.submit "Save Changes", class: "btn btn-primary px-4 me-2" %>
        <%= link_to "Cancel", directory_path(@person), class: "btn btn-outline-secondary px-4" %>
      </div>

    </div>
  <% end %>
</div>
