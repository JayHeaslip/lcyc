<div class="card-body p-4">
  <div class="row g-4">
    
    <!-- Main Content -->
    <div class="col-12 col-lg-8">
      
      <!-- Name -->
      <h2 class="h4 fw-semibold text-dark mb-4"><%= "#{@person.FirstName} #{@person.LastName}" %></h2>
      
      <!-- Details -->
      <div class="row g-2">
        
        <!-- First Name -->
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium">First Name</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= @person.FirstName %></div>
            </div>
          </div>
        </div>
        
        <!-- Last Name -->
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Last Name</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= @person.LastName %></div>
            </div>
          </div>
        </div>
        
        <!-- Primary Email -->
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Email</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2">
                <a href="mailto:#{@person.EmailAddress}" class="text-primary text-decoration-none"><%= @person.EmailAddress %></a>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Primary Phone -->
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Cell Phone</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= number_to_phone(@person.CellPhone, area_code:true) %></div>
            </div>
          </div>
        </div>

        <!-- Mailing Address -->
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Address</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= address(@person.membership) %></div>
            </div>
          </div>
        </div>
        
      </div>
    </div>

    <!-- Photo Area -->
    <div class="col-12 col-lg-4 d-flex justify-content-center justify-content-lg-end">
      <div class="border border-2 border-secondary bg-light text-muted rounded overflow-hidden shadow-sm flex-shrink-0"
	   style="width: 260px; height: 260px;"> 
	
	<% if @person.profile_picture.attached? %>
	<%= image_tag @person.profile_picture, 
            class: "w-100 h-100 object-cover", 
            alt: "#{@person.FirstName} #{@person.LastName} Profile Photo" %>
	<% else %>
	<div class="d-flex align-items-center justify-content-center h-100 text-center font-monospace lh-sm">
          <div>
            <p class="mb-1 text-uppercase fw-semibold tracking-wide">Photo</p>
            <p class="mb-1 text-uppercase fw-semibold tracking-wide">Not</p>
            <p class="mb-0 text-uppercase fw-semibold tracking-wide">Available</p>
          </div>
	</div>
	<% end %>
	
      </div>
    </div>
  </div>
  
  <% if Current.user.person == @person %>
    <%= link_to "Edit", edit_directory_path(@person) %> |
  <% end %>
  <%= link_to "Back", directory_index_path %>
</div>
