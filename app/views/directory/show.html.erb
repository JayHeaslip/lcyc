<div class="card-body p-4">
  <div class="row g-4">
    
    <!-- Main Content -->
    <div class="col-12 col-lg-8">
      
      <!-- Name -->
      <h2 class="h4 fw-semibold text-dark mb-4"><%= "#{@person.FirstName} #{@person.LastName}" %></h2>
      
      <!-- Details -->
      <div class="row g-2">
        
        <!-- First Name -->
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium">First Name</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= @person.FirstName %></div>
            </div>
          </div>
        </div>
        
        <!-- Last Name -->
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Last Name</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= @person.LastName %></div>
            </div>
          </div>
        </div>
        
        <!-- Primary Email -->
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Email</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2">
                <a href="mailto:#{@person.EmailAddress}" class="text-primary text-decoration-none"><%= @person.EmailAddress %></a>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Primary Phone -->
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Cell Phone</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= @person.CellPhone %></div>
            </div>
          </div>
        </div>

        <!-- Mailing Address -->
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium">Address</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= address(@person.membership) %></div>
            </div>
          </div>
        </div>
        
      </div>
    </div>

    <!-- Photo Area -->
    <div class="col-12 col-lg-4 d-flex justify-content-center justify-content-lg-end">
      <div class="border border-2 bg-black text-white d-flex align-items-center justify-content-center rounded"
           style="width: 220px; height: 220px; font-size: 1.1rem; text-align: center; line-height: 1.3;">
	<div class="border border-2 border-light rounded overflow-hidden shadow-sm flex-shrink-0"
	     style="width: 260px; height: 260px;">   <!-- Fixed square size -->
	  <% unless @person.display_photo.nil? %>
            <%= image_tag @person.display_photo, 
                class: "w-100 h-100 object-cover", 
                alt: "#{@person.FirstName} #{@person.LastName} Profile Photo" %>
	  <% else %>
            <p>Photo</p>
	    <p>Not</p>
            <p>Available</p>
	  <% end %>
	  
        </div>
      </div>
    </div>
  </div>
</div>
