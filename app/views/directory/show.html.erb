<div class="max-w-4xl mx-auto my-8 p-6 bg-white">
  
  <!-- Main Profile Grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    
    <!-- Left Column: Member Details -->
    <div class="md:col-span-2 space-y-4">

      <!-- Data Fields -->
      <div class="space-y-3 pt-4">
        <div class="grid grid-cols-3 py-1">
          <span class="text-gray-600 italic">Last Name</span>
          <span class="col-span-2 text-gray-900 font-medium"><%= @person.LastName %></span>
        </div>
        
        <div class="grid grid-cols-3 py-1">
          <span class="text-gray-600 italic">First Name</span>
          <span class="col-span-2 text-gray-900 font-medium"><%= @person.FirstName %></span>
        </div>

	<\!-- Right Column: Avatar/Photo Placeholder -\-> -->
	  <div class="md:col-span-1 flex flex-col items-center md:items-start">
	    <% if @person.profile_picture.attached? %> 
	      <%= image_tag @person.profile_picture, class: "w-64 h-64 object-cover border border-gray-200" %>
	    <% else %>
	    <div class="w-64 h-64 bg-black text-white flex flex-col items-center justify-center font-bold text-center p-4 tracking-wider uppercase">
	      <div>Photo</div>
	      <div>Not</div>
	      <div>Available</div>

            </div>
	    <% end %>
	  </div>
	  <%= link_to "Edit", edit_directory_path(@person) %>
  </div>
</div>
