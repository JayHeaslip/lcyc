<div class="card-body p-4">
  <div class="row g-4">
    
    <div class="col-12 col-lg-8">
      
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4 pb-3 border-bottom">
        <h2 class="h4 fw-bold text-dark mb-0">
          <%= "#{@person.FirstName} #{@person.LastName}" %>
        </h2>
        
        <div class="d-flex gap-2">
          <%= link_to directory_index_path, class: "btn btn-outline-secondary btn-sm px-3 rounded-pill d-inline-flex align-items-center" do %>
            <span>Back</span>
          <% end %>

          <% if current_user.membership == @person.MembershipID || current_user.admin? %>
            <%= link_to edit_directory_path(@person), class: "btn btn-primary btn-sm px-3 rounded-pill d-inline-flex align-items-center shadow-sm" do %>
              <span>Edit Profile</span>
            <% end %>
          <% end %>
        </div>
      </div>
      
      <div class="row g-2">
        
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">First Name</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark fw-semibold"><%= @person.FirstName %></div>
            </div>
          </div>
        </div>
        
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Last Name</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark fw-semibold"><%= @person.LastName %></div>
            </div>
          </div>
        </div>
        
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Partner</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark fw-semibold"><%= @person.partner %></div>
            </div>
          </div>
        </div>
        
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Category</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark fw-semibold"><%= @person.membership.Status %></div>
            </div>
          </div>
        </div>
        
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Member Since</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark fw-semibold"><%= @person.membership.MemberSince %></div>
            </div>
          </div>
        </div>
        
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Committee</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark fw-semibold"><%= @person.Committee1 %></div>
            </div>
          </div>
        </div>
        
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Email</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2">
                <a href="mailto:#{@person.EmailAddress}" class="text-primary text-decoration-none fw-medium"><%= @person.EmailAddress %></a>
              </div>
            </div>
          </div>
        </div>
        
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Cell Phone</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= number_to_phone(@person.CellPhone, area_code:true) %></div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Home Phone</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= number_to_phone(@person.HomePhone, area_code:true) %></div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Work Phone</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= number_to_phone(@person.WorkPhone, area_code:true) %></div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Address</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= address(@person.membership) %></div>
            </div>
          </div>
        </div>
        
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Boat Name</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= @boat&.Name %></div>
            </div>
          </div>
        </div>
        
        <div class="col-12">
          <div class="row align-items-center">
            <div class="col-4 col-md-3">
              <div class="bg-light text-muted px-3 py-2 rounded fw-medium small">Boat Mfg/Type</div>
            </div>
            <div class="col-8 col-md-9">
              <div class="py-2 text-dark"><%= @boat&.Mfg_Size %></div>
            </div>
          </div>
        </div>
        
      </div>
    </div>

    <div class="col-12 col-lg-4 d-flex flex-column align-items-center align-items-lg-end gap-4">
      <div class="border border-light-subtle bg-light text-muted rounded-4 overflow-hidden shadow-sm flex-shrink-0"
           style="width: 260px; height: 260px;"> 
    
        <% if @person.profile_picture.attached? %>
          <%= image_tag @person.profile_picture, 
                    class: "w-100 h-100 object-cover", 
                    alt: "#{@person.FirstName} #{@person.LastName} Profile Photo" %>
        <% else %>
          <div class="d-flex align-items-center justify-content-center h-100 text-center font-monospace lh-sm text-secondary bg-body-tertiary">
            <div>
              <p class="mb-1 text-uppercase fw-semibold tracking-wide small">Profile Photo</p>
              <p class="mb-0 text-muted small">Not Available</p>
            </div>
          </div>
        <% end %>
    
      </div>

      <div class="border border-light-subtle bg-light text-muted rounded-4 overflow-hidden shadow-sm flex-shrink-0"
           style="width: 260px; height: 260px;"> 
    
        <% if @boat&.photo&.attached? %>
          <%= image_tag @boat.photo, 
                    class: "w-100 h-100 object-cover", 
                    alt: "#{@boat.Name} Photo" %>
        <% else %>
          <div class="d-flex align-items-center justify-content-center h-100 text-center font-monospace lh-sm text-secondary bg-body-tertiary">
            <div>
              <p class="mb-1 text-uppercase fw-semibold tracking-wide small">Boat Photo</p>
              <p class="mb-0 text-muted small">Not Available</p>
            </div>
          </div>
        <% end %>
    
      </div>
    </div>
  </div>
</div>
