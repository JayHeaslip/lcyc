<div class="row g-3 max-width-form"> <div class="col-12">
    <%= form.label :password, "New Password", class: "form-label fw-medium small text-muted" %>
    <%= form.password_field :password, 
        required: true, 
        class: "form-control rounded-3", 
        placeholder: "••••••••" %>
  </div>

  <div class="col-12">
    <%= form.label :password_confirmation, "Confirm New Password", class: "form-label fw-medium small text-muted" %>
    <%= form.password_field :password_confirmation, 
        required: true, 
        class: "form-control rounded-3", 
        placeholder: "••••••••" %>
  </div>

  <div class="col-12 pt-2">
    <div class="d-grid">
      <%= form.submit "Update Password", class: "btn btn-primary btn-lg rounded-pill fw-semibold shadow-sm" %>
    </div>
  </div>

</div>
