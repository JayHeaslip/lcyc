<div class="container d-flex justify-content-center align-items-center my-5">
  <div class="card shadow-sm border-0 p-4 rounded-3" style="max-width: 450px; width: 100%;">
    
    <div class="text-center mb-4">
      <div class="bg-primary-subtle text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 48px; height: 48px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-shield-lock" viewBox="0 0 100 100">
          </svg>
      </div>
      <h3 class="h4 fw-bold text-dark mb-2">Create New Password</h3>
      <p class="text-muted small">Your token has been verified. Please enter and confirm your secure new password below.</p>
    </div>

    <%= form_with url: password_path(params[:password_reset_token]), method: :put do |form| %>
      <%= render "form", form: form %>
    <% end %>

  </div>
</div>
