<div class="container d-flex justify-content-center align-items-center my-5">
  <div class="card shadow border-0 p-4 rounded-3" style="max-width: 420px; width: 100%;">
    
    <div class="text-center mb-4">
      <p class="text-muted small">Please sign in to access your account.</p>
    </div>

    <%= form_with url: login_url, local: true do |f| %>
      
      <div class="form-floating mb-3">
        <%= f.email_field :email, class: "form-control rounded-3", id: "email", placeholder: "name@example.com", required: true %>
        <%= f.label :email, "Email Address" %>
      </div>

      <div class="form-floating mb-3">
        <%= f.password_field :password, class: "form-control rounded-3", id: "password", placeholder: "Password", required: true %>
        <%= f.label :password, "Password" %>
      </div>

      <div class="d-flex justify-content-between align-items-center mb-4 small">
        <div class="form-check form-switch mb-0">
          <%= f.check_box :remember_me, class: "form-check-input", id: "remember_me" %>
          <%= f.label :remember_me, "Remember me", class: "form-check-label text-muted fw-medium" %>
        </div>
        <%= link_to "Forgot password?", new_password_path, class: "text-primary text-decoration-none fw-medium" %>
      </div>

      <div class="d-grid mb-3">
        <%= f.submit "Sign In", class: "btn btn-primary btn-lg rounded-pill fw-semibold shadow-sm" %>
      </div>

      <div class="text-center pt-2 border-top">
        <p class="text-muted small mb-0">
          New here? 
          <%= link_to "Create an account", sign_up_path, class: "text-primary text-decoration-none fw-semibold ms-1" %>
        </p>
      </div>

    <% end %>

  </div>
</div>
