<%= form_with model: @user, url: url, local: true do |f| %>
  
  <% if @user.errors.any? %>
    <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-3 mb-4" role="alert">
      <div class="d-flex align-items-center mb-2">
        <strong class="h6 mb-0 text-danger fw-bold">
          <%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:
        </strong>
      </div>
      <ul class="mb-0 small ps-3">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4 pb-2 border-bottom">
    <h3 class="h5 fw-bold text-dark mb-1">User Details</h3>
    <p class="text-muted small">Please use the email listed in the log so you'll be recognized.</p>
  </div>
  
  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6">
      <div class="form-floating">
        <%= f.text_field :firstname, id: "firstname", class: "form-control rounded-3", placeholder: "John" %>
        <%= f.label :firstname, "First Name" %>
      </div>
    </div>
    <div class="col-12 col-md-6">
      <div class="form-floating">
        <%= f.text_field :lastname, id: "lastname", class: "form-control rounded-3", placeholder: "Doe" %>
        <%= f.label :lastname, "Last Name" %>
      </div>
    </div>
  </div>

  <% if new || (Current.user && Current.user.admin?) %>
    <div class="row g-3 mb-3">
      <div class="col-12">
        <div class="form-floating">
          <%= f.email_field :email, id: "email", class: "form-control rounded-3", placeholder: "name@example.com" %>
          <%= f.label :email, "Email Address" %>
        </div>
      </div>
      
      <div class="col-12 col-md-6">
        <div class="form-floating">
          <%= f.password_field :password, value: nil, id: "password", class: "form-control rounded-3", placeholder: "••••••••" %>
          <%= f.label :password, "Password" %>
        </div>
      </div>
      
      <div class="col-12 col-md-6">
        <div class="form-floating">
          <%= f.password_field :password_confirmation, value: nil, id: "password_confirmation", class: "form-control rounded-3", placeholder: "••••••••" %>
          <%= f.label :password_confirmation, "Confirm Password" %>
        </div>
      </div>
    </div>
  <% end %>

  <% if Current.user && Current.user.admin? %>
    <div class="card bg-light border-0 rounded-3 p-3 mb-4 mt-4 shadow-sm">
      <span class="d-block fw-bold text-secondary small text-uppercase tracking-wider mb-3">Administrative Controls</span>
      
      <div class="form-check form-switch mb-3">
        <%= check_box_tag :email_confirmed, "1", !@user.confirmed_at.nil?, class: "form-check-input", id: "email_confirmed" %>
        <%= f.label :email_confirmed, "Confirm user email manually", class: "form-check-label text-dark fw-medium" %>
      </div>

      <div class="row align-items-center g-2">
        <div class="col-12 col-sm-auto">
          <%= f.label :role_id, "Assigned Role:", class: "form-label text-muted small fw-medium mb-sm-0" %>
        </div>
        <div class="col-12 col-sm-4">
          <%= f.select :role_id, Role.all.collect { |r| [r.name, r.id] }, {}, { class: "form-select form-select-sm rounded-3 fw-medium" } %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="d-flex align-items-center gap-3 mt-4 pt-2">
    <%= f.submit button, class: "btn btn-primary px-4 rounded-pill fw-semibold shadow-sm" %>
    <%= link_to 'Cancel', url_for(:back), class: "btn btn-outline-secondary px-4 rounded-pill" %>
  </div>

  <% end %>
