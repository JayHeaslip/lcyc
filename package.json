{
    "name": "app",
    "private": "true",
    "dependencies": {
	"@hotwired/stimulus": "^3.2.2",
	"@hotwired/turbo-rails": "^8.0.21",
	"@popperjs/core": "^2.11.8",
	"@rails/actiontext": "^7.1.3",
	"bootstrap": "^5.3.3",
	"bootstrap-icons": "^1.11.3",
	"esbuild": "^0.28.1",
	"sass": "^1.77.8",
	"trix": "^2.1.18"
    },
    "scripts": {
	"build": "esbuild app/javascript/*.* --bundle --sourcemap --outdir=app/assets/builds",
	"build:css": "sass ./app/assets/stylesheets/application.bootstrap.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules --quiet-deps"
    },
    "engines": {
	"node": ">=18"
    }
}
